# ===========================================
# LinkedIn Automation Configuration
# ===========================================

# Groq API Key (get from https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# LinkedIn OAuth 2.0 Credentials
# Get these from https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_URN=your_linkedin_person_urn

# Server Configuration
PORT=3000

# Scheduling (24-hour format, e.g., "09:00" for 9 AM)
POST_TIME=09:00

# Timezone
TIMEZONE=Asia/Kolkata
